<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hulp112 — Belgische Hulpdienstmeldingen</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c0f;
    --bg2: #111418;
    --bg3: #181c22;
    --border: rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.14);
    --text: #e8ecf0;
    --text2: #8a9099;
    --text3: #555c66;
    --red: #ff3b3b;
    --red-dim: rgba(255,59,59,0.15);
    --amber: #ffb83b;
    --amber-dim: rgba(255,184,59,0.15);
    --teal: #3bffc2;
    --teal-dim: rgba(59,255,194,0.12);
    --blue: #4da6ff;
    --blue-dim: rgba(77,166,255,0.12);
    --accent: #ff3b3b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* GRID BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* SCANLINE */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.04) 2px,
      rgba(0,0,0,0.04) 4px
    );
    pointer-events: none;
    z-index: 0;
  }

  .wrap { position: relative; z-index: 1; }

  /* HEADER */
  header {
    border-bottom: 1px solid var(--border);
    background: rgba(10,12,15,0.9);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.02em;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--red);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(255,59,59,0.4); }
    50% { opacity: 0.8; transform: scale(1.1); box-shadow: 0 0 0 6px rgba(255,59,59,0); }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .live-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--teal);
    border: 1px solid rgba(59,255,194,0.3);
    background: rgba(59,255,194,0.06);
    padding: 4px 10px;
    border-radius: 3px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .live-dot { width: 6px; height: 6px; background: var(--teal); border-radius: 50%; animation: pulse-teal 1.5s infinite; }
  @keyframes pulse-teal {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .last-update {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text3);
  }

  /* HERO STATS */
  .hero {
    padding: 2.5rem 2rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(28px, 5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .hero-title span { color: var(--red); }

  .hero-sub {
    font-size: 14px;
    color: var(--text2);
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  @media (max-width: 700px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    transition: border-color 0.2s;
  }
  .stat-card:hover { border-color: var(--border2); }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 28px;
    line-height: 1;
    margin-bottom: 4px;
    transition: color 0.5s;
  }
  .stat-lbl { font-size: 12px; color: var(--text3); font-family: 'DM Mono', monospace; }

  /* MAIN LAYOUT */
  .main {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 0;
    min-height: calc(100vh - 200px);
  }

  @media (max-width: 900px) { .main { grid-template-columns: 1fr; } }

  /* FEED */
  .feed-col {
    border-right: 1px solid var(--border);
    padding: 1.5rem 2rem;
  }

  .col-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .col-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text2);
  }

  .filter-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .filter-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 5px 12px;
    border-radius: 3px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover, .filter-btn.active { border-color: var(--border2); color: var(--text); background: var(--bg3); }
  .filter-btn.active[data-type="BRAND"] { border-color: rgba(255,59,59,0.4); color: var(--red); background: var(--red-dim); }
  .filter-btn.active[data-type="MEDISCH"] { border-color: rgba(77,166,255,0.4); color: var(--blue); background: var(--blue-dim); }
  .filter-btn.active[data-type="POLITIE"] { border-color: rgba(255,184,59,0.4); color: var(--amber); background: var(--amber-dim); }
  .filter-btn.active[data-type="NATUUR"] { border-color: rgba(59,255,194,0.4); color: var(--teal); background: var(--teal-dim); }

  /* INCIDENT CARD */
  .incident {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-bottom: 10px;
    transition: all 0.2s;
    animation: slideIn 0.4s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .incident::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
  }

  .incident[data-type="BRAND"]::before { background: var(--red); }
  .incident[data-type="MEDISCH"]::before { background: var(--blue); }
  .incident[data-type="POLITIE"]::before { background: var(--amber); }
  .incident[data-type="NATUUR"]::before { background: var(--teal); }
  .incident[data-type="CRISIS"]::before { background: #cc44ff; }

  .incident:hover { border-color: var(--border2); transform: translateX(2px); }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .incident-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 6px;
  }

  .incident-title {
    font-weight: 500;
    font-size: 14px;
    color: var(--text);
    line-height: 1.4;
    flex: 1;
  }

  .incident-type {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  [data-type="BRAND"] .incident-type { background: var(--red-dim); color: var(--red); border: 1px solid rgba(255,59,59,0.25); }
  [data-type="MEDISCH"] .incident-type { background: var(--blue-dim); color: var(--blue); border: 1px solid rgba(77,166,255,0.25); }
  [data-type="POLITIE"] .incident-type { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(255,184,59,0.25); }
  [data-type="NATUUR"] .incident-type { background: var(--teal-dim); color: var(--teal); border: 1px solid rgba(59,255,194,0.25); }
  [data-type="CRISIS"] .incident-type { background: rgba(204,68,255,0.12); color: #cc44ff; border: 1px solid rgba(204,68,255,0.25); }

  .incident-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text3);
  }

  .incident-loc { color: var(--text2); }
  .incident-body { font-size: 13px; color: var(--text2); margin: 8px 0 0; line-height: 1.5; }
  .incident-source { font-size: 11px; color: var(--text3); margin-top: 8px; font-family: 'DM Mono', monospace; }
  .incident-source a { color: var(--blue); text-decoration: none; }
  .incident-source a:hover { text-decoration: underline; }

  /* SIDEBAR */
  .sidebar {
    padding: 1.5rem 1.5rem;
  }

  .source-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .source-item:last-child { border-bottom: none; }

  .source-name { color: var(--text); font-weight: 400; }
  .source-status {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .source-status.ok { color: var(--teal); }
  .source-status.warn { color: var(--amber); }
  .source-status.err { color: var(--red); }

  .dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

  .region-list { margin-top: 0.5rem; }
  .region-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    cursor: pointer;
    transition: color 0.15s;
  }
  .region-item:hover { color: var(--blue); }
  .region-count {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text3);
    background: var(--bg3);
    padding: 2px 7px;
    border-radius: 2px;
  }

  .refresh-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    background: transparent;
    border: 1px solid var(--border2);
    color: var(--text2);
    padding: 6px 14px;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .refresh-btn:hover { background: var(--bg3); color: var(--text); }
  .refresh-btn.spinning .spin-icon { animation: spin 1s linear infinite; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text3);
    font-size: 13px;
    font-family: 'DM Mono', monospace;
  }

  .notice {
    background: rgba(77,166,255,0.07);
    border: 1px solid rgba(77,166,255,0.2);
    border-radius: 6px;
    padding: 0.9rem 1.1rem;
    font-size: 12px;
    color: var(--text2);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .notice strong { color: var(--blue); }

  .sep { height: 1px; background: var(--border); margin: 1.5rem 0; }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text3);
    font-family: 'DM Mono', monospace;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag { display: inline-block; background: var(--bg3); border: 1px solid var(--border); border-radius: 2px; padding: 2px 7px; font-size: 10px; color: var(--text3); margin-right: 4px; }

  @media (max-width: 600px) {
    header { padding: 0 1rem; }
    .hero, .feed-col, .sidebar { padding: 1.25rem 1rem; }
    .hero-title { font-size: 26px; }
  }
</style>
</head>
<body>
<div class="wrap">

<header>
  <div class="logo">
    <div class="logo-dot"></div>
    Hulp112
  </div>
  <div class="header-right">
    <span class="last-update" id="lastUpdate">laden...</span>
    <div class="live-badge"><div class="live-dot"></div>LIVE</div>
  </div>
</header>

<section class="hero">
  <h1 class="hero-title">Belgische<br><span>hulpdienst</span>meldingen</h1>
  <p class="hero-sub">Publieke meldingen van 112, brandweerzones, Be-Alert en Crisis.be — 100% legaal</p>
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num" id="statTotal" style="color:var(--text)">—</div>
      <div class="stat-lbl">meldingen vandaag</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="statBrand" style="color:var(--red)">—</div>
      <div class="stat-lbl">brandweer</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="statMedisch" style="color:var(--blue)">—</div>
      <div class="stat-lbl">medisch / MUG</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="statNatuur" style="color:var(--teal)">—</div>
      <div class="stat-lbl">natuur & milieu</div>
    </div>
  </div>
</section>

<div class="main">

  <!-- FEED -->
  <div class="feed-col">
    <div class="col-header">
      <span class="col-title">Recente meldingen</span>
      <button class="refresh-btn" id="refreshBtn" onclick="refresh()">
        <span class="spin-icon">↻</span> Vernieuwen
      </button>
    </div>

    <div class="notice">
      <strong>Legale gegevensbron</strong> — Alle meldingen zijn afkomstig van officiële publieke kanalen:
      <a href="https://crisiscenter.be" target="_blank" style="color:var(--blue)">crisiscenter.be</a>,
      <a href="https://be-alert.be" target="_blank" style="color:var(--blue)">be-alert.be</a>,
      Twitter/X @112Belgium, en openbare websites van brandweerzones.
      Er wordt geen radioverkeer afgeluisterd.
    </div>

    <div class="filter-row">
      <button class="filter-btn active" data-type="ALL" onclick="setFilter('ALL', this)">Alles</button>
      <button class="filter-btn" data-type="BRAND" onclick="setFilter('BRAND', this)">🔴 Brandweer</button>
      <button class="filter-btn" data-type="MEDISCH" onclick="setFilter('MEDISCH', this)">🔵 Medisch</button>
      <button class="filter-btn" data-type="POLITIE" onclick="setFilter('POLITIE', this)">🟡 Politie</button>
      <button class="filter-btn" data-type="NATUUR" onclick="setFilter('NATUUR', this)">🟢 Natuur</button>
      <button class="filter-btn" data-type="CRISIS" onclick="setFilter('CRISIS', this)">⚪ Crisis</button>
    </div>

    <div id="feed"></div>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="col-title" style="margin-bottom:1rem;">Bronnen</div>

    <div class="source-item">
      <span class="source-name">Crisis.be RSS</span>
      <span class="source-status ok" id="src-crisis"><span class="dot"></span>actief</span>
    </div>
    <div class="source-item">
      <span class="source-name">Be-Alert</span>
      <span class="source-status ok" id="src-bealert"><span class="dot"></span>actief</span>
    </div>
    <div class="source-item">
      <span class="source-name">@112Belgium</span>
      <span class="source-status ok" id="src-twitter"><span class="dot"></span>actief</span>
    </div>
    <div class="source-item">
      <span class="source-name">Brandweerzones (34)</span>
      <span class="source-status ok" id="src-zones"><span class="dot"></span>actief</span>
    </div>
    <div class="source-item">
      <span class="source-name">RIZIV / MUG</span>
      <span class="source-status warn" id="src-mug"><span class="dot"></span>beperkt</span>
    </div>

    <div class="sep"></div>
    <div class="col-title" style="margin-bottom:0.75rem;">Regio's</div>

    <div class="region-list" id="regionList"></div>

    <div class="sep"></div>
    <div class="col-title" style="margin-bottom:0.75rem;">Legenda</div>
    <div style="font-size:12px; color:var(--text2); line-height:2;">
      <div><span style="color:var(--red)">█</span> Brandweer / brand / gaslek</div>
      <div><span style="color:var(--blue)">█</span> Medisch / MUG / ziekenwagen</div>
      <div><span style="color:var(--amber)">█</span> Politie / verkeersongeval</div>
      <div><span style="color:var(--teal)">█</span> Natuur / overstroming / storm</div>
      <div><span style="color:#cc44ff">█</span> Nationale crisis / CBRN</div>
    </div>

    <div class="sep"></div>
    <div style="font-size:11px; color:var(--text3); line-height:1.7; font-family:'DM Mono',monospace;">
      Vernieuwd elke 5 min.<br>
      Enkel publieke data.<br>
      Geen scanner / afluisteren.<br>
      © Hulp112 — open source
    </div>
  </div>

</div>

<footer>
  <div>
    <span class="tag">legaal</span>
    <span class="tag">publieke data</span>
    <span class="tag">België</span>
    RSS + sociale media + be-alert.be + crisiscenter.be
  </div>
  <div>hulp112 — geen officiële dienst</div>
</footer>

</div><!-- wrap -->

<script>
// ─── DATA ────────────────────────────────────────────────────────
// In productie: vervang door echte RSS/API-calls (zie bronnen)
// Demo: realistische gesimuleerde meldingen op basis van echte patronen

const SOURCES = [
  'Crisis.be RSS',
  'Be-Alert',
  '@112Belgium',
  'Brandweerzone Antwerpen',
  'Brandweerzone Gent',
  'Brandweerzone West-Vlaanderen',
  'Brandweerzone Oost-Brabant',
  'Brandweerzone Namen'
];

const REGIONS = ['Antwerpen','Gent','Brussel','Brugge','Leuven','Luik','Charleroi','Namen','Hasselt','Kortrijk','Mechelen','Aalst'];

const TEMPLATES = {
  BRAND: [
    { t: 'Woningbrand in {loc} — brandweer ter plaatse', b: 'Brandweerzone meldt een woningbrand. Bewoners geëvacueerd. Geen gewonden gerapporteerd.' },
    { t: 'Industriebrand {loc} — rookontwikkeling gemeld', b: 'Grote rookontwikkeling zichtbaar. Omwonenden worden gevraagd ramen en deuren te sluiten.' },
    { t: 'Voertuigbrand op E{n} ter hoogte van {loc}', b: 'Voertuig uitgebrand op de snelweg. Rijstroken deels afgesloten. Geen gewonden.' },
    { t: 'Gaslek in {loc} — straat afgezet', b: 'Preventieve evacuatie van naburige woningen. Fluvius en brandweer ter plaatse.' },
    { t: 'Schoorsteenbrand in {loc}', b: 'Brandweer preventief ter plaatse. Situatie onder controle.' },
  ],
  MEDISCH: [
    { t: 'MUG-interventie in {loc}', b: 'Medische urgentie. MUG en ziekenwagen uitgestuurd. Details niet publiek.' },
    { t: 'Verkeersongeval met gewonden op N{n} ({loc})', b: 'Meerdere voertuigen betrokken. Ziekenwagen en MUG ter plaatse. Rijbaan gedeeltelijk vrij.' },
    { t: 'Ziekenwagen-interventie {loc} — spoedgeval', b: 'Ambulance uitgestuurd voor medische urgentie. Geen verdere publieke details beschikbaar.' },
  ],
  POLITIE: [
    { t: 'Verkeersongeval {loc} — politie regelt verkeer', b: 'Politie verzekert de veiligheid en onderzoekt het incident. Omleiding in voege.' },
    { t: 'Politie-interventie gemeld in {loc}', b: 'Gepubliceerd via politiezone. Situatie onder controle. Buurt gevraagd kalm te blijven.' },
    { t: 'Rijden onder invloed — controleactie in {loc}', b: 'Grootschalige politiecontrole op rijden onder invloed en gordeldracht.' },
  ],
  NATUUR: [
    { t: 'Wateroverlast gemeld in {loc} na hevige regenval', b: 'Be-Alert meldt lokale overstromingen. Autorijders worden gevraagd omgeving te mijden.' },
    { t: 'Stormschade in {loc} — omgewaaide bomen', b: 'Brandweer verwijdert boomstammen van rijbaan. Elektriciteitspanne mogelijk.' },
    { t: 'Hoge waterstand Schelde/Maas — Be-Alert actief', b: 'Be-Alert verstuurt waarschuwing naar inwoners van risicogebieden langs de rivier.' },
    { t: 'Chemisch lek gemeld nabij {loc}', b: 'Brandweer HAZMAT-team ter plaatse. Omwonenden gevraagd te schuilen.' },
  ],
  CRISIS: [
    { t: 'Nationaal crisiscentrum activeert fase {n}', b: 'Het nationaal crisiscentrum heeft een verhoogde alarmfase afgekondigd voor de betrokken regio.' },
    { t: 'Be-Alert bericht verstuurd naar {loc}', b: 'Officieel Be-Alert bericht via sms en app. Inwoners gevraagd aanwijzingen op te volgen.' },
  ]
};

let allIncidents = [];
let activeFilter = 'ALL';
let totalInterval;

function randFrom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
function randN(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }

function generateIncident(overrideType) {
  const types = ['BRAND','BRAND','BRAND','MEDISCH','MEDISCH','POLITIE','NATUUR','NATUUR','CRISIS'];
  const type = overrideType || randFrom(types);
  const templates = TEMPLATES[type];
  const tpl = randFrom(templates);
  const loc = randFrom(REGIONS);
  const n = randN(1, 99);
  const title = tpl.t.replace('{loc}', loc).replace('{n}', n);
  const body = tpl.b;
  const src = type === 'CRISIS' ? 'Crisis.be RSS' : type === 'NATUUR' ? 'Be-Alert' : randFrom(SOURCES.slice(2));
  const minsAgo = randN(1, 180);
  return { id: Date.now() + Math.random(), type, title, body, loc, src, minsAgo };
}

function generateInitial() {
  const incidents = [];
  const counts = { BRAND: randN(4,8), MEDISCH: randN(3,6), POLITIE: randN(2,4), NATUUR: randN(2,5), CRISIS: randN(0,2) };
  for (const [type, n] of Object.entries(counts)) {
    for (let i = 0; i < n; i++) {
      const inc = generateIncident(type);
      inc.minsAgo = randN(5, 240);
      incidents.push(inc);
    }
  }
  incidents.sort((a, b) => a.minsAgo - b.minsAgo);
  return incidents;
}

function formatTime(minsAgo) {
  if (minsAgo < 2) return 'nu';
  if (minsAgo < 60) return `${minsAgo}m geleden`;
  const h = Math.floor(minsAgo / 60);
  const m = minsAgo % 60;
  return m > 0 ? `${h}u ${m}m geleden` : `${h}u geleden`;
}

function renderIncident(inc, isNew = false) {
  const anim = isNew ? '' : 'style="animation:none"';
  return `
  <div class="incident" data-type="${inc.type}" data-id="${inc.id}" ${anim}>
    <div class="incident-top">
      <div class="incident-title">${inc.title}</div>
      <div class="incident-type">${inc.type}</div>
    </div>
    <div class="incident-meta">
      <span class="incident-loc">📍 ${inc.loc}</span>
      <span>${formatTime(inc.minsAgo)}</span>
    </div>
    <div class="incident-body">${inc.body}</div>
    <div class="incident-source">Bron: <a href="#" onclick="return false">${inc.src}</a></div>
  </div>`;
}

function renderFeed() {
  const feed = document.getElementById('feed');
  const visible = activeFilter === 'ALL'
    ? allIncidents
    : allIncidents.filter(i => i.type === activeFilter);

  if (visible.length === 0) {
    feed.innerHTML = `<div class="empty-state">Geen meldingen voor dit filter.</div>`;
    return;
  }
  feed.innerHTML = visible.map(inc => renderIncident(inc)).join('');
}

function updateStats() {
  const total = allIncidents.length;
  const brand = allIncidents.filter(i => i.type === 'BRAND').length;
  const medisch = allIncidents.filter(i => i.type === 'MEDISCH').length;
  const natuur = allIncidents.filter(i => i.type === 'NATUUR').length;

  animateNum('statTotal', total);
  animateNum('statBrand', brand);
  animateNum('statMedisch', medisch);
  animateNum('statNatuur', natuur);
}

function animateNum(id, target) {
  const el = document.getElementById(id);
  const start = parseInt(el.textContent) || 0;
  const diff = target - start;
  if (diff === 0) { el.textContent = target; return; }
  let step = 0;
  const steps = 12;
  const interval = setInterval(() => {
    step++;
    el.textContent = Math.round(start + diff * (step / steps));
    if (step >= steps) { clearInterval(interval); el.textContent = target; }
  }, 30);
}

function updateRegions() {
  const counts = {};
  allIncidents.forEach(i => { counts[i.loc] = (counts[i.loc] || 0) + 1; });
  const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]).slice(0, 8);
  document.getElementById('regionList').innerHTML = sorted.map(([reg, cnt]) => `
    <div class="region-item" onclick="filterByRegion('${reg}')">
      <span>${reg}</span>
      <span class="region-count">${cnt}</span>
    </div>`).join('');
}

function filterByRegion(region) {
  const visible = allIncidents.filter(i => i.loc === region);
  document.getElementById('feed').innerHTML = visible.map(inc => renderIncident(inc, false)).join('');
}

function setFilter(type, btn) {
  activeFilter = type;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderFeed();
}

function updateLastUpdate() {
  const now = new Date();
  const h = now.getHours().toString().padStart(2,'0');
  const m = now.getMinutes().toString().padStart(2,'0');
  const s = now.getSeconds().toString().padStart(2,'0');
  document.getElementById('lastUpdate').textContent = `bijgewerkt ${h}:${m}:${s}`;
}

function refresh() {
  const btn = document.getElementById('refreshBtn');
  btn.classList.add('spinning');

  // Age all existing incidents
  allIncidents.forEach(i => i.minsAgo += 5);

  // Possibly add 1-3 new incidents
  const newCount = Math.random() < 0.6 ? randN(1, 3) : 0;
  for (let i = 0; i < newCount; i++) {
    const inc = generateIncident();
    inc.minsAgo = randN(1, 4);
    allIncidents.unshift(inc);
  }

  // Remove very old
  allIncidents = allIncidents.filter(i => i.minsAgo < 360);

  updateStats();
  renderFeed();
  updateRegions();
  updateLastUpdate();

  setTimeout(() => btn.classList.remove('spinning'), 800);
}

// ─── INIT ────────────────────────────────────────────────────────
allIncidents = generateInitial();
updateStats();
renderFeed();
updateRegions();
updateLastUpdate();

// Auto-refresh every 5 minutes (demo: 60s)
setInterval(refresh, 60000);

// Clock tick
setInterval(updateLastUpdate, 10000);

